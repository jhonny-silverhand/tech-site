# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
# Full walkthroughs for every value below live in /Guides.

# --- Supabase (Guides/01-database-setup.md) ---
# Public — safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret — server only, never prefix with NEXT_PUBLIC_. Used by /api/admin/* routes
# to bypass Row Level Security so the admin can manage every user's posts.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin login (Guides/00-how-to-run.md) ---
# The single admin account described in the project spec. Generate the value with:
#   npm run hash-password -- "your-real-password"
# (Printed pre-encoded as base64 — that's deliberate, see the comment in
# scripts/hash-password.mjs. Paste the base64 string exactly as printed.)
ADMIN_EMAIL=admin@tech-site.local
ADMIN_PASSWORD_HASH_B64=
# Random long string used to sign the admin session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# --- AI drafting (Guides/02-api-setup.md) ---
# Free key from https://aistudio.google.com/apikey — used only by the admin's
# "Generate draft" button. Regular users never touch this.
GEMINI_API_KEY=
